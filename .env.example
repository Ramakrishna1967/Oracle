# ─── Slack Credentials ────────────────────────────────
# Bot token (xoxb-) — from OAuth & Permissions page
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App-level token (xapp-) — from Basic Information > App-Level Tokens
# Must have connections:write scope for Socket Mode
SLACK_APP_TOKEN=xapp-your-app-token

# Signing secret — from Basic Information > App Credentials
SLACK_SIGNING_SECRET=your-signing-secret

# ─── Redis ────────────────────────────────────────────
# Connection URL for Redis (used by BullMQ and rate limiters)
REDIS_URL=redis://127.0.0.1:6379

# ─── Oracle Configuration ─────────────────────────────
# Confidence threshold to fire a brief (0-100, minimum 75)
CONFIDENCE_THRESHOLD=85

# Max DMs per user per 60-minute window
MAX_DMS_PER_USER_PER_HOUR=3

# Max DMs across entire workspace per 60-minute window
MAX_DMS_PER_WORKSPACE_PER_HOUR=20

# Fallback channel ID — briefs go here if DM delivery fails
FALLBACK_CHANNEL_ID=C0000000000

# ─── MCP Servers ──────────────────────────────────────
# GitHub MCP server command (leave empty to disable)
MCP_GITHUB_COMMAND=npx
MCP_GITHUB_ARGS=-y,@modelcontextprotocol/server-github

# Jira MCP server command (leave empty to disable)
MCP_JIRA_COMMAND=npx
MCP_JIRA_ARGS=-y,@modelcontextprotocol/server-jira

# ─── Server ───────────────────────────────────────────
# Express health server port
PORT=3000

# Log level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Node environment
NODE_ENV=development
